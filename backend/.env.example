APP_NAME=SignalGabon
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Stockage fichiers : "local" en dev, "r2" en prod (Cloudflare R2)
FILESYSTEM_DISK=local

# Cloudflare R2 (activer avec FILESYSTEM_DISK=r2)
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=signal-gabon-preuves
CLOUDFLARE_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

QUEUE_CONNECTION=sync
CACHE_STORE=file

# Notifications email citoyen
# "log" pour tester localement, "smtp" ou "mailgun" en prod
MAIL_MAILER=log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@signal-gabon.ga
MAIL_FROM_NAME="SignalGabon"

SANCTUM_STATEFUL_DOMAINS=your-citizen-app.vercel.app,your-admin-app.vercel.app

CORS_ALLOWED_ORIGINS=https://your-citizen-app.vercel.app,https://your-admin-app.vercel.app
